# Frontend build-time config for the contact form (public values — exposed in the
# client bundle by Vite). Real values live in .env.development / .env.production.
#
# Turnstile widget SITE key (public). Dev test key 1x00000000000000000000AA always passes.
VITE_TURNSTILE_SITE_KEY=
# URL of the deployed contact Worker (e.g. https://portfolio-contact.<acct>.workers.dev).
VITE_CONTACT_ENDPOINT=
